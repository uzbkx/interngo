{
  "name": "interngo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "scouter": "npx tsx src/lib/scouter/scheduler.ts",
    "scouter:once": "npx tsx -e \"import('./src/lib/scouter/scheduler.ts')\"",
    "test": "npx playwright test",
    "test:visual": "npx playwright test --project=agent-1-visual",
    "test:code": "npx playwright test --project=agent-2-code-review",
    "test:functional": "npx playwright test --project=agent-3-functional",
    "test:report": "npx playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@base-ui/react": "^1.3.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.5.0",
    "@prisma/pg-worker": "^6.9.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "dotenv": "^17.3.1",
