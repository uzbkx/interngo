generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ORGANIZATION
  ADMIN
}

enum ListingType {
  INTERNSHIP
  SCHOLARSHIP
  PROGRAM
  VOLUNTEER
  JOB
  OTHER
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ListingSource {
  USER_SUBMITTED
  AI_SCOUTED
}

enum ApplicationStatus {
  INTERESTED
  APPLIED
  INTERVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(STUDENT)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization? @relation("OrgOwner")
  savedListings  SavedListing[]
  applications   Application[]

  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  website     String?
  logoUrl     String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId  String   @unique
  owner    User     @relation("OrgOwner", fields: [ownerId], references: [id])
  listings Listing[]

  @@map("organizations")
}

model Category {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  listings ListingCategory[]

  @@map("categories")
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String
  type        ListingType
  status      ListingStatus @default(DRAFT)
  source      ListingSource @default(USER_SUBMITTED)

  location    String?
  isRemote    Boolean       @default(false)
  isPaid      Boolean       @default(false)
  salary      String?
  currency    String?

  applyUrl    String?
  applyEmail  String?

  deadline    DateTime?
  startDate   DateTime?
  endDate     DateTime?

  country     String?
  city        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  categories    ListingCategory[]
  savedBy       SavedListing[]
  applications  Application[]

  @@index([type, status])
  @@index([country])
  @@index([deadline])
  @@map("listings")
}

model ListingCategory {
  listingId  String
  categoryId String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([listingId, categoryId])
  @@map("listing_categories")
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("saved_listings")
}

model Application {
  id        String            @id @default(uuid())
  userId    String
  listingId String
  status    ApplicationStatus @default(INTERESTED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("applications")
}

model ScoutedSource {
  id          String   @id @default(uuid())
  name        String
  url         String   @unique
  description String?
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results ScoutedResult[]

  @@map("scouted_sources")
}

model ScoutedResult {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String?
  rawData     Json?
  isApproved  Boolean  @default(false)
  isRejected  Boolean  @default(false)
  createdAt   DateTime @default(now())

  sourceId  String
  source    ScoutedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  listingId String?

  @@map("scouted_results")
}

model ScouterRun {
  id            String   @id @default(uuid())
  type          String   // "scheduled", "manual", "discovery"
  status        String   // "running", "completed", "failed"
  sourcesCount  Int      @default(0)
  foundCount    Int      @default(0)
  addedCount    Int      @default(0)
  autoApproved  Int      @default(0)
  errors        String[]
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@map("scouter_runs")
}
